#!/bin/sh
# claude-memex pre-commit — gentle nudge when sensitive files change.
#
# Does NOT block the commit. Use `claude-memex check --strict` in CI for
# actual enforcement. This hook only prints a reminder.
#
# Activate (once per clone):
#   git config core.hooksPath .claude/hooks
#
# Then `chmod +x .claude/hooks/pre-commit` if your platform needs it.

if command -v claude-memex >/dev/null 2>&1; then
  claude-memex check --staged 2>/dev/null || true
else
  npx --no-install claude-memex check --staged 2>/dev/null || true
fi

exit 0
